{
	"compilerOptions": {
		"rootDir": "src",
		"lib": ["ESNext"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2022",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"sourceMap": true,
		"allowJs": true,
		"noEmit": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"types": ["node"]
	},
	"include": ["**/src/**/*.ts"]
}
