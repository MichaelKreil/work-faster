{
  "name": "work-faster",
  "version": "2.5.5",
  "description": "same as array.forEach, but in parallel",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "npm run format && npm run lint && npm run build && npm run test",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint . --color",
    "prepack": "npm run build",
    "release": "npx vrt release-npm",
    "test-coverage": "vitest run --coverage",
    "test": "vitest run",
    "upgrade": "npm-check-updates -u && rm -f package-lock.json; rm -rf node_modules; npm i"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "author": "Michael Kreil <github@michael-kreil.de> (https://github.com/MichaelKreil)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MichaelKreil/work-faster.git"
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@versatiles/release-tool": "^2.7.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "npm-check-updates": "^19.3.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
